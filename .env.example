# Django settings
SECRET_KEY=replace-this-with-a-secure-key
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost

# Supabase / Storage settings
# Set these on Render (or your hosting) as Environment Variables

# Supabase project URL (include https://)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (keep secret)
SUPABASE_ACCESS_KEY=your_service_role_key
SUPABASE_SECRET_KEY=your_service_role_key

# Bucket name used for media (default 'media')
AWS_STORAGE_BUCKET_NAME=media
AWS_S3_REGION_NAME=ap-southeast-1

# Optional: override if you want custom domain for media
# AWS_S3_CUSTOM_DOMAIN=https://cdn.example.com/media
